rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the authenticated user can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollections (stats per game, history)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Leaderboard: authenticated users can read all, write only their own entry
    match /leaderboard/{game}/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Weekly challenges: read-only for authenticated users (admin writes)
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
